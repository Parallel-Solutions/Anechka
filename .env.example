# BITRIX_WEBHOOK_URL=   # необязательно; обычно задаётся на странице Настройки
# OPENAI_API_KEY=       # необязательно; можно задать на странице Настройки
OPENAI_MODEL=gpt-4o
OPENAI_BITRIX_METADATA_MODEL=
APP_SECRET_KEY=change-me

# HTTP Basic Auth (пустой пароль = auth отключён)
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=change-me

# Bootstrap admin (app_users, для будущего session-auth)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me
COOKIE_SECURE=false

# PostgreSQL
POSTGRES_USER=bitrix
POSTGRES_PASSWORD=bitrix
POSTGRES_DB=bitrix_export
# Внутри docker-сети БД доступна как db:5432 (compose переопределяет DATABASE_URL).
# Для доступа с хоста используйте dev-override: docker compose -f docker-compose.yml -f docker-compose.dev.yml up
# (публикует PostgreSQL на localhost:5433).
DATABASE_URL=postgresql+psycopg://bitrix:bitrix@db:5432/bitrix_export

# Тесты: docker compose exec web pytest
# Для тестов миграций на реальном Postgres (опционально):
# TEST_DATABASE_URL=postgresql+psycopg://bitrix:change-me@db:5432/bitrix_export_test

EXPORT_DIR=./exports
FILE_STORAGE_DIR=./filestorage
LOG_LEVEL=INFO

# Bitrix import worker
WORKER_POLL_INTERVAL=2.0
WORKER_HEARTBEAT_INTERVAL=30.0
WORKER_STALE_RUN_MINUTES=15
IMPORT_BATCH_SIZE=50
IMPORT_OVERLAP_MINUTES=10
BITRIX_METADATA_PROMPT_VERSION=1
BITRIX_IMPORT_SCHEDULE_ENABLED=true
BITRIX_IMPORT_SCHEDULE_INTERVAL_MINUTES=60

# Call result import / LLM classification
BITRIX_SERVICE_USER_ID=0
CALL_RESULTS_BITRIX_EXECUTION_ENABLED=false
BITRIX_CALL_SOURCE_FIELD_CODE=
BITRIX_CALL_SOURCE_FIELD_VALUE=
POSITIVE_ACTIVITY_DEFAULT_DEADLINE=24h
CALL_RESULTS_TIMEZONE=Europe/Moscow
CALL_RESULTS_MAX_EXECUTION_RETRIES=3
CONTACT_SEARCH_PROVIDER=fake
CONTACT_SEARCH_AUTO_CONFIRM_THRESHOLD=0.95
LLM_CALL_RESULTS_ENABLED=true
LLM_CALL_RESULTS_USE_MOCK=false
LLM_CALL_RESULTS_CONFIDENCE_THRESHOLD=0.80
LLM_CALL_RESULTS_CONCURRENCY=3
LLM_CALL_RESULTS_CACHE_ENABLED=true
# LLM_CALL_RESULTS_MODEL=gpt-4o-mini
CALL_RESULT_MAX_FILE_BYTES=52428800
CALL_RESULT_MAX_ROWS=100000
