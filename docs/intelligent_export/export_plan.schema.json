{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bitrix-export.local/schemas/export_plan/v1.json",
  "title": "ExportPlan",
  "description": "Формальный план выгрузки CRM. Генерируется AI, валидируется сервером. AI не должен добавлять произвольные поля вне catalog_ref.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "title", "sources", "output"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/Source" }
    },
    "joins": {
      "type": "array",
      "maxItems": 10,
      "items": { "$ref": "#/$defs/Join" }
    },
    "columns": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": { "$ref": "#/$defs/Column" }
    },
    "transforms": {
      "type": "array",
      "maxItems": 50,
      "items": { "$ref": "#/$defs/Transform" }
    },
    "sort": {
      "type": "array",
      "maxItems": 5,
      "items": { "$ref": "#/$defs/SortKey" }
    },
    "group_by": {
      "type": "array",
      "maxItems": 10,
      "items": { "$ref": "#/$defs/FieldRef" }
    },
    "validation_rules": {
      "type": "array",
      "maxItems": 20,
      "items": { "$ref": "#/$defs/ValidationRule" }
    },
    "output": { "$ref": "#/$defs/Output" },
    "memory_refs": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["memory_id", "kind"],
        "properties": {
          "memory_id": { "type": "integer" },
          "kind": { "type": "string", "enum": ["term", "alias", "mapping", "template", "rule"] }
        }
      }
    }
  },
  "$defs": {
    "EntityTypeId": {
      "type": "integer",
      "enum": [1, 2, 3, 4]
    },
    "FieldRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type_id", "field_code"],
      "properties": {
        "entity_type_id": { "$ref": "#/$defs/EntityTypeId" },
        "field_code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "pattern": "^[A-Za-z0-9_]+$"
        },
        "source_alias": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      }
    },
    "FilterOp": {
      "type": "string",
      "enum": [
        "eq", "ne", "gt", "gte", "lt", "lte",
        "in", "not_in", "contains", "starts_with",
        "is_null", "is_not_null"
      ]
    },
    "Filter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "op"],
      "properties": {
        "field": { "$ref": "#/$defs/FieldRef" },
        "op": { "$ref": "#/$defs/FilterOp" },
        "value": {},
        "values": {
          "type": "array",
          "maxItems": 100
        }
      }
    },
    "Source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alias", "entity_type_id"],
      "properties": {
        "alias": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "entity_type_id": { "$ref": "#/$defs/EntityTypeId" },
        "filters": {
          "type": "array",
          "maxItems": 30,
          "items": { "$ref": "#/$defs/Filter" }
        },
        "include_deleted": {
          "type": "boolean",
          "default": false
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50000
        }
      }
    },
    "Join": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "from_alias", "to_alias", "from_field", "to_field"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["inner", "left"]
        },
        "from_alias": { "type": "string" },
        "to_alias": { "type": "string" },
        "from_field": { "$ref": "#/$defs/FieldRef" },
        "to_field": { "$ref": "#/$defs/FieldRef" }
      }
    },
    "Column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["header", "field"],
      "properties": {
        "header": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "field": { "$ref": "#/$defs/FieldRef" },
        "transform_id": {
          "type": "string",
          "maxLength": 64
        },
        "sheet": {
          "type": "string",
          "maxLength": 31
        },
        "width": {
          "type": "integer",
          "minimum": 5,
          "maximum": 100
        }
      }
    },
    "TransformOp": {
      "type": "string",
      "enum": [
        "none",
        "trim",
        "uppercase",
        "lowercase",
        "phone_normalize",
        "phone_format_display",
        "date_format",
        "number_format",
        "dictionary_label",
        "mapping_lookup",
        "default_value"
      ]
    },
    "Transform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "op"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "op": { "$ref": "#/$defs/TransformOp" },
        "params": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "SortKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "direction"],
      "properties": {
        "field": { "$ref": "#/$defs/FieldRef" },
        "direction": {
          "type": "string",
          "enum": ["asc", "desc"]
        }
      }
    },
    "ValidationRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "field"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["required", "regex", "min_length", "max_length", "in_dictionary"]
        },
        "field": { "$ref": "#/$defs/FieldRef" },
        "params": {
          "type": "object",
          "additionalProperties": true
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning"],
          "default": "error"
        }
      }
    },
    "OutputSheet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 31
        },
        "column_headers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "include_errors": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "Output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["xlsx", "csv"]
        },
        "sheets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 15,
          "items": { "$ref": "#/$defs/OutputSheet" }
        },
        "include_params_sheet": {
          "type": "boolean",
          "default": true
        },
        "filename_label": {
          "type": "string",
          "maxLength": 60
        }
      }
    }
  }
}
