      "title": "CoalesceValue",
      "type": "object"
    },
    "Column": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "maxLength": 64,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_]*$",
