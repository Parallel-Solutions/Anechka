            "propertyName": "kind"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/FieldValue"
            },
            {
              "$ref": "#/$defs/ConstantValue"
            },
            {
              "$ref": "#/$defs/ConcatValue"
            },
            {
              "$ref": "#/$defs/CoalesceValue"
            },
            {
              "$ref": "#/$defs/ConditionalValue"
